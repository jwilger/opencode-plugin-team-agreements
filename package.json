{
  "name": "opencode-plugin-team-agreements",
  "version": "0.1.3",
  "description": "OpenCode plugin for establishing and maintaining team agreements for human-LLM collaboration",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build",
    "prepare": "lefthook install"
  },
  "keywords": [
    "opencode",
    "plugin",
    "team-agreements",
    "collaboration",
    "llm",
    "ai",
    "developer-tools"
  ],
  "author": "John Wilger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jwilger/opencode-plugin-team-agreements.git"
  },
  "bugs": {
    "url": "https://github.com/jwilger/opencode-plugin-team-agreements/issues"
  },
  "homepage": "https://github.com/jwilger/opencode-plugin-team-agreements#readme",
  "devDependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "@types/node": "^25.0.10",
    "lefthook": "^2.0.15",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.0.0"
  }
}
